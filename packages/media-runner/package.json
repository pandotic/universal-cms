{
  "name": "@pandotic/media-runner",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone Node worker that runs Anthropic Managed Agents sessions for the Marketing Agency. Polls hub_agent_runs, opens streams, persists results.",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@pandotic/universal-cms": "workspace:*",
    "@supabase/supabase-js": "^2.102.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.3"
  }
}
