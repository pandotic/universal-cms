# ─────────────────────────────────────────────────────────────────────────────
# Pandotic Hub (fleet-dashboard) — required environment variables
# Copy to .env.local for development, set these in Netlify for production.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (Hub project: rimbgolutrxpmwsoswhq) ─────────────────────────────
# Public keys — used by browser + SSR middleware
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only keys — used by API routes and API Central
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Auth ─────────────────────────────────────────────────────────────────────
# Single-password login for the dashboard (see /api/auth)
APP_PASSWORD=choose-a-strong-password

# ─────────────────────────────────────────────────────────────────────────────
# Optional — enable these features by setting the corresponding vars
# ─────────────────────────────────────────────────────────────────────────────

# Agent webhooks — required for external agent runners to report status
# AGENT_WEBHOOK_SECRET=random-shared-secret

# Claude API — required for /social/generate and the AI chat helpers
# ANTHROPIC_API_KEY=sk-ant-...

# GitHub OAuth — required for /api/auth/github (repo PR creation via deploy wizard)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# API Central — override default /api base (leave unset in most cases)
# NEXT_PUBLIC_API_BASE=/api

# PMF Evaluator — embeds the standalone app at /tools/pmf-evaluator
# NEXT_PUBLIC_PMF_EVALUATOR_URL=https://pmf-evaluator.netlify.app
