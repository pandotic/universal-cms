{
  "name": "universal-cms",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "type-check": "npm run type-check --workspaces --if-present",
    "clean": "rm -rf packages/*/dist apps/*/dist"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
