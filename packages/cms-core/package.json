    "class-variance-authority": ">=0.7.0",
    "lucide-react": ">=0.400.0",
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "tailwindcss": ">=4.0.0",
