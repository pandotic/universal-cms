{
  "name": "@pandotic/universal-cms",
  "version": "0.1.0",
  "description": "Universal CMS for Next.js + Supabase sites — modular admin panel, analytics, content management",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts", "development": "./src/index.ts" },
    "./config": { "import": "./dist/config.js", "types": "./dist/config.d.ts", "development": "./src/config.ts" },
    "./types": { "import": "./dist/types/index.js", "types": "./dist/types/index.d.ts", "development": "./src/types/index.ts" },
    "./security": { "import": "./dist/security/index.js", "types": "./dist/security/index.d.ts", "development": "./src/security/index.ts" },
    "./middleware": { "import": "./dist/middleware/index.js", "types": "./dist/middleware/index.d.ts", "development": "./src/middleware/index.ts" },
    "./version": { "import": "./dist/version.js", "types": "./dist/version.d.ts", "development": "./src/version.ts" },
