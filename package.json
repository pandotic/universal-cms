{
  "private": true,
  "scripts": {
    "test": "pnpm --filter @pandotic/universal-cms test",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm --filter @pandotic/universal-cms build && pnpm --filter @pandotic/skill-library build",
    "build:all": "pnpm --filter @pandotic/universal-cms build && pnpm --filter @pandotic/skill-library build && pnpm --filter @pandotic/fleet-dashboard build && pnpm --filter universal-cms-template build",
    "verify": "pnpm -r typecheck && pnpm test && pnpm build:all",
    "ai-context": "tsx scripts/generate-ai-context.ts",
    "ai-context:check": "tsx scripts/generate-ai-context.ts --check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "supabase": "^2.0.0",
    "tsx": "^4.19.2",
    "vitest": "^4.1.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.1.6",
      "@types/react-dom": "19.1.6"
    }
  }
}
