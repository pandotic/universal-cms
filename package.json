{
  "name": "@pandotic/universal-cms",
  "version": "0.1.0",
  "description": "Universal CMS for Next.js + Supabase sites — modular admin panel, analytics, content management",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/config.ts",
    "./types": "./src/types/index.ts",
    "./security": "./src/security/index.ts",
    "./data/content": "./src/data/content-pages.ts",
    "./data/media": "./src/data/media.ts",
    "./data/reviews": "./src/data/reviews.ts",
    "./data/directory": "./src/data/directory.ts",
    "./data/analytics": "./src/data/analytics.ts",
    "./analytics": "./src/analytics/index.ts",
    "./components/admin": "./src/components/admin/index.ts",
    "./components/ui": "./src/components/ui/index.ts"
  },
  "files": ["src", "migrations", "templates"],
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "@supabase/ssr": ">=0.5.0",
    "@supabase/supabase-js": ">=2.0.0",
    "tailwindcss": ">=4.0.0",
    "zod": ">=3.0.0"
  },
  "keywords": ["cms", "next.js", "supabase", "admin-panel", "content-management"],
  "repository": {
    "type": "git",
    "url": "https://github.com/pandotic/universal-cms"
  },
  "license": "MIT",
  "author": "Pandotic"
}
